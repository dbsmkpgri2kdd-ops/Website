
{
  "entities": {
    "Exam": {
      "title": "Exam",
      "description": "Jadwal dan konfigurasi ujian online (ExamBro).",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "class": { "type": "string" },
        "day": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "token": { "type": "string" },
        "url": { "type": "string" },
        "isActive": { "type": "boolean" },
        "teacherName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "School": {
      "title": "School",
      "description": "Profil utama sekolah dan pengaturan website.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "shortName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "vision": { "type": "string" },
        "mission": { "type": "array", "items": { "type": "string" } },
        "principalName": { "type": "string" },
        "principalMessage": { "type": "string" },
        "history": { "type": "string" },
        "logoUrl": { "type": "string" },
        "isMaintenanceMode": { "type": "boolean" },
        "selectedTemplate": { "type": "string" },
        "primaryColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "layoutSettings": { "type": "object" },
        "studentCount": { "type": "number" },
        "teacherCount": { "type": "number" },
        "industryPartnerCount": { "type": "number" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Profil pengguna dan peran dalam sistem.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "guru", "siswa", "alumni"] }
      }
    },
    "PortfolioItem": {
      "title": "PortfolioItem",
      "description": "Karya atau proyek yang diunggah oleh siswa.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "projectUrl": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "studentName": { "type": "string" },
        "studentClass": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Data profil pengguna."
    },
    "/schools/{schoolId}/exams/{examId}": {
      "schema": "#/backend/entities/Exam",
      "description": "Basis data ujian online."
    },
    "/users/{userId}/portfolio/{id}": {
      "schema": "#/backend/entities/PortfolioItem",
      "description": "Koleksi karya digital siswa."
    },
    "/schools/{schoolId}": {
      "schema": "#/backend/entities/School",
      "description": "Konfigurasi utama sekolah."
    }
  }
}
