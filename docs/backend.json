{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile with their role in the system.",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["admin", "guru", "siswa", "alumni"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "School": {
      "title": "School",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "shortName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "vision": { "type": "string" },
        "mission": { "type": "array", "items": { "type": "string" } },
        "principalName": { "type": "string" },
        "principalMessage": { "type": "string" },
        "isMaintenanceMode": { "type": "boolean" },
        "primaryColor": { "type": "string" },
        "accentColor": { "type": "string" }
      }
    }
  },
  "auth": { "providers": ["password"] },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "/schools/{schoolId}": {
      "schema": { "$ref": "#/backend/entities/School" },
      "description": "Stores school information."
    }
  }
}