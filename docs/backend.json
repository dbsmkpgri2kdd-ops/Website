
{
  "entities": {
    "School": {
      "title": "School",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "shortName": { "type": "string" },
        "address": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "guru", "siswa", "alumni"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "User profiles and roles."
    },
    "/schools/{schoolId}": {
      "schema": "#/backend/entities/School",
      "description": "General school configuration."
    },
    "/schools/{schoolId}/newsArticles/{id}": {
      "schema": "NewsArticle",
      "description": "School news articles."
    },
    "/schools/{schoolId}/quickLinks/{id}": {
      "schema": "QuickLink",
      "description": "Dashboard shortcut links."
    }
  }
}
