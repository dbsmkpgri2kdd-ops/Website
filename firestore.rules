
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         exists(/databases/$(database)/documents/app_roles/admins/$(request.auth.uid)));
    }

    // --- COLLECTION RULES ---

    // Aturan Pengguna: Mengizinkan user pertama/baru membuat profil dan Admin mengelolanya
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Khusus untuk Prototyping: Mengizinkan user mengubah role-nya sendiri ke admin 
      // jika belum ada admin atau untuk setup awal.
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /school_settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /schools/{schoolId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /student_enrollments/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /app_roles/admins/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }
  }
}
