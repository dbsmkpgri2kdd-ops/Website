
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNGSI PEMBANTU ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        // Mode Setup: Izinkan pendaftar pertama jadi admin jika flag sistem belum ada
        (!exists(/databases/$(database)/documents/app_roles/initialized/init/system)) || 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- ATURAN KOLEKSI ---

    // 1. Profil Pengguna & Portofolio
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      match /portfolio/{itemId} {
        // Izinkan baca jika ditandai publik, atau pemiliknya sendiri, atau admin
        allow read: if resource.data.isPublic == true || (isSignedIn() && request.auth.uid == userId) || isAdmin();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 2. Data Sekolah (Akses Publik)
    match /schools/{schoolId} {
      allow read: if true; // Izinkan siapa pun membaca data sekolah
      allow write: if isAdmin();

      // Izinkan baca semua sub-koleksi publik (berita, jurusan, dll)
      match /{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // Khusus: Formulir yang bisa diisi pengunjung (Public Forms)
      match /contactMessages/{id} { allow create: if true; }
      match /studentApplications/{id} { allow create: if true; }
      match /guestbookEntries/{id} { allow create: if true; }
      match /tracerStudyResponses/{id} { allow create: if true; }
      match /extracurricularApplications/{id} { allow create: if true; }
    }

    // 3. DUKUNGAN COLLECTION GROUP (Penting untuk Fitur Showcase Karya)
    // Mengizinkan query lintas folder portfolio untuk item yang ditandai publik
    match /{path=**}/portfolio/{portfolioId} {
      allow read: if resource.data.isPublic == true;
    }

    // 4. Sistem Inisialisasi & Role
    match /app_roles/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
